# 复制为 .env 后由 docker compose 读取：  cp .env.example .env
#
# 构建镜像前仓库中需存在 license/public.pem（可 tools/generate_keys.py 生成后只提交公钥）
#
# === API 鉴权（前后端一致；不设则不要求 Bearer）===
# 生产建议：openssl rand -hex 32
SHARK_API_TOKEN=
# 前端：本地 dev 可设 web/.env.local 的 VITE_SHARK_API_TOKEN；Docker 同源页面由 /api/bootstrap.js 运行时注入，无需打进镜像
# VITE_SHARK_API_TOKEN=

# === 许可证（生产请关闭跳过校验并挂载 license/license.key）===
# 1=跳过许可证（仅开发/纸面）；生产设为 0 或不写
SKIP_LICENSE_CHECK=0

# Docker：容器内指纹与签发机不一致时必须设置。填 license.key 里 JSON 的 machine_fingerprint（整段 hex，无引号）
# 与 docker-compose.yml 同目录的 .env 才会被 compose 加载；改完后需：docker compose up -d --force-recreate
# 若环境变量无法进容器：在挂载目录 license/ 下放置 fingerprint_override（仅一行 hex），见 license/fingerprint_override.example
# 例：SHARK_LICENSE_FINGERPRINT=8c8adcaec282d4a92fcfb66af1e011fac21aaaabaf5534893b390bb81cb8456b
SHARK_LICENSE_FINGERPRINT=

# === Nginx 宿主机端口（默认 80）===
SHARK_HTTP_PORT=80
# 日志级别：DEBUG/INFO/WARNING（主进程 configure_logging；行内含 [rid=请求关联ID]）
SHARK_LOG_LEVEL=INFO
# 1=容器启动后模拟盘自动交易；0=必须前端手动点击「开始交易」。
# SHARK_AUTO_START_PAPER=0

# === 设备锁（1=启用；未授权来源 403 返回 static/device_denied.png）===
# 浏览器无法上报真实 MAC，默认按来源 IP：本机用 http://127.0.0.1:<port>，或把允许的 IP 写入列表。
# 生产/实盘建议 docker compose 只绑定 127.0.0.1，并通过显式白名单或受控反代访问。
# SHARK_DEVICE_LOCK=1
# SHARK_ALLOWED_IPS=127.0.0.1,::1
# 若日志出现 Cloudflare Tunnel 等来源（如 172.64.x.x，非 RFC1918 私网），需追加单 IP 或 CIDR：
# SHARK_ALLOWED_IPS=127.0.0.1,::1,172.64.144.82
# SHARK_ALLOWED_CIDRS=172.64.0.0/13
# 默认 0：只信任显式 IP/CIDR。确需局域网共享时才设 1。
# SHARK_DEVICE_LOCK_ALLOW_PRIVATE=0
# 可选：与本机 ifconfig「ether」一致；bootstrap 向已放行 IP 注入后，业务 API 自动带 MAC；首页与静态资源仅校验 IP（浏览器无法带头）。
# SHARK_ALLOWED_MAC=
# SHARK_TRUST_X_FORWARDED_FOR=0
# SHARK_DEVICE_DENY_IMAGE=

# === Postgres / Redis（Compose 已注入时可省略；本地开发填本地连接串）===
# DATABASE_URL=postgresql://shark:shark@localhost:5432/shark
# SHARK_REDIS_URL=redis://localhost:6379/0


# === 可选：显式配置文件路径（一般无需改）===
# SHARK_CONFIG_PATH=/app/config/settings.yaml

# === 交易所 / LLM（可与 config/settings.yaml 二选一；环境变量优先于 YAML 空字段）===
# GATE_API_KEY=
# GATE_API_SECRET=
# DEEPSEEK_API_KEY=
# 看板娘台词：未设置 CHARACTER_LLM_KEY 时使用 DEEPSEEK_API_KEY；CHARACTER_LLM=0 关闭「每笔开平仓 LLM 一句」
# CHARACTER_LLM_URL=https://api.deepseek.com/v1/chat/completions
# CHARACTER_LLM_MODEL=deepseek-chat
# CHARACTER_LLM=0
# DIALOGUE_AMMO=0
# DARWIN_LLM_API_KEY=
